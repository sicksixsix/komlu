<!-- res/navigation/nav_graph.xml -->
<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/homeFragment">

    <!-- HOME -->
    <fragment
        android:id="@+id/homeFragment"
        android:name="com.komiklu.app.ui.home.HomeFragment"
        android:label="Home"
        tools:layout="@layout/fragment_home">

        <action
            android:id="@+id/action_home_to_detail"
            app:destination="@id/detailFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />

        <action
            android:id="@+id/action_home_to_reader"
            app:destination="@id/readerActivity" />
    </fragment>

    <!-- ALL SERIES -->
    <fragment
        android:id="@+id/allSeriesFragment"
        android:name="com.komiklu.app.ui.series.AllSeriesFragment"
        android:label="Semua Series"
        tools:layout="@layout/fragment_all_series">

        <argument
            android:name="filterGenre"
            app:argType="string"
            android:defaultValue="" />

        <action
            android:id="@+id/action_series_to_detail"
            app:destination="@id/detailFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />
    </fragment>

    <!-- PROJECT -->
    <fragment
        android:id="@+id/projectFragment"
        android:name="com.komiklu.app.ui.project.ProjectFragment"
        android:label="Project Kami"
        tools:layout="@layout/fragment_all_series">

        <action
            android:id="@+id/action_project_to_detail"
            app:destination="@id/detailFragment" />
    </fragment>

    <!-- DETAIL -->
    <fragment
        android:id="@+id/detailFragment"
        android:name="com.komiklu.app.ui.detail.DetailFragment"
        android:label="Detail"
        tools:layout="@layout/fragment_detail">

        <argument
            android:name="comicTitle"
            app:argType="string" />

        <action
            android:id="@+id/action_detail_to_reader"
            app:destination="@id/readerActivity" />

        <action
            android:id="@+id/action_detail_to_all_series"
            app:destination="@id/allSeriesFragment" />
    </fragment>

    <!-- FAVORITES -->
    <fragment
        android:id="@+id/favoritesFragment"
        android:name="com.komiklu.app.ui.favorites.FavoritesFragment"
        android:label="Favorit"
        tools:layout="@layout/fragment_favorites">

        <action
            android:id="@+id/action_favorites_to_detail"
            app:destination="@id/detailFragment" />
    </fragment>

    <!-- PROFILE -->
    <fragment
        android:id="@+id/profileFragment"
        android:name="com.komiklu.app.ui.profile.ProfileFragment"
        android:label="Profil"
        tools:layout="@layout/fragment_profile">

        <action
            android:id="@+id/action_profile_to_login"
            app:destination="@id/loginFragment"
            app:popUpTo="@id/profileFragment"
            app:popUpToInclusive="true" />

        <action
            android:id="@+id/action_profile_to_history"
            app:destination="@id/historyFragment" />

        <action
            android:id="@+id/action_profile_to_favorites"
            app:destination="@id/favoritesFragment" />
    </fragment>

    <!-- READ HISTORY -->
    <fragment
        android:id="@+id/historyFragment"
        android:name="com.komiklu.app.ui.history.ReadHistoryFragment"
        android:label="Riwayat Baca">

        <action
            android:id="@+id/action_history_to_reader"
            app:destination="@id/readerActivity" />
    </fragment>

    <!-- LOGIN / REGISTER -->
    <fragment
        android:id="@+id/loginFragment"
        android:name="com.komiklu.app.ui.auth.LoginFragment"
        android:label="Login"
        tools:layout="@layout/fragment_login">

        <action
            android:id="@+id/action_login_to_register"
            app:destination="@id/registerFragment" />

        <action
            android:id="@+id/action_login_success"
            app:destination="@id/homeFragment"
            app:popUpTo="@id/loginFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/registerFragment"
        android:name="com.komiklu.app.ui.auth.RegisterFragment"
        android:label="Daftar"
        tools:layout="@layout/fragment_register">

        <action
            android:id="@+id/action_register_success"
            app:destination="@id/homeFragment"
            app:popUpTo="@id/loginFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <!-- READER — Activity terpisah untuk fullscreen -->
    <activity
        android:id="@+id/readerActivity"
        android:name="com.komiklu.app.ui.reader.ReaderActivity"
        android:label="Reader">

        <argument android:name="comicTitle" app:argType="string" />
        <argument android:name="chapter" app:argType="string" />
        <argument android:name="chapterUrl" app:argType="string" />
    </activity>

</navigation>
